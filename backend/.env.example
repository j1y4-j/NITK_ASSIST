# Server Configuration
PORT=5000

# JWT Security
JWT_SECRET=your_jwt_secret_here

# MySQL Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=nitk_assist
DB_DIALECT=mysql

# AI Service Connection
AI_SERVICE_URL=http://localhost:8000

# Prisma URL for MySQL
DATABASE_URL="mysql://root:your_db_password@localhost:3306/nitk_assist"

# API Key for secure cron jobs/workers
SYSTEM_API_KEY="your_worker_api_key_here"
